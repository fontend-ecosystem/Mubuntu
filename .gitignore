/assets/ubuntu-rootfs/*.tar
/assets/ubuntu-rootfs/*.tar.*
/assets/ubuntu-rootfs/*.img

# Local SDK/framework artifacts used outside the Gradle build
/libs/

# Editor/system noise
.DS_Store
Thumbs.db
